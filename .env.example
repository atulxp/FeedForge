# ============================================================
# FEEDFORGE - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ────────────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
APP_SECRET=your-super-secret-32-char-key-here

# ────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://zpf_user:zpf_pass@localhost:5432/zpf_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=zpf_db
DATABASE_USER=zpf_user
DATABASE_PASSWORD=zpf_pass

# ────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ────────────────────────────────────────────────────────────
# S3 / OBJECT STORAGE (MinIO for local dev, AWS S3 for prod)
# ────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET=zpf-media
S3_REGION=ap-south-1
S3_PUBLIC_URL=http://localhost:9000/zpf-media

# ────────────────────────────────────────────────────────────
# JWT AUTH
# ────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ────────────────────────────────────────────────────────────
# ENCRYPTION (for OAuth tokens at rest)
# AES-256 key — must be exactly 32 bytes / 64 hex chars
# ────────────────────────────────────────────────────────────
ENCRYPTION_KEY=replace-with-64-character-hex-key

# ────────────────────────────────────────────────────────────
# UNIFIED SOCIAL PROVIDER
# Choose ONE: ayrshare | zernio | none (direct only)
# ────────────────────────────────────────────────────────────
SOCIAL_PROVIDER=ayrshare

# Ayrshare (https://ayrshare.com) — recommended for v1
AYRSHARE_API_KEY=your-ayrshare-api-key

# Zernio (https://zernio.com) — budget alternative
ZERNIO_API_KEY=your-zernio-api-key

# ────────────────────────────────────────────────────────────
# META (Instagram + Facebook + Threads)
# https://developers.facebook.com
# ────────────────────────────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:4000/auth/meta/callback

# ────────────────────────────────────────────────────────────
# YOUTUBE (Google)
# https://console.cloud.google.com
# ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
YOUTUBE_QUOTA_DAILY_LIMIT=10000

# ────────────────────────────────────────────────────────────
# X (Twitter)
# https://developer.x.com
# ────────────────────────────────────────────────────────────
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=http://localhost:4000/auth/x/callback
# Budget cap for X reads (USD per day before alerts fire)
X_DAILY_READ_BUDGET_USD=5.00

# REDDIT
# Create a "web app" at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:4000/api/accounts/oauth/reddit/callback
REDDIT_USER_AGENT=feedforge/0.1 by your-reddit-username

# ────────────────────────────────────────────────────────────
# LINKEDIN
# https://developer.linkedin.com
# NOTE: Requires Marketing Developer Platform partner approval
# ────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:4000/auth/linkedin/callback

# ────────────────────────────────────────────────────────────
# TIKTOK
# https://developers.tiktok.com
# NOTE: Content posting is PRIVATE until audit passes (2-6 weeks)
# ────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:4000/auth/tiktok/callback

# ────────────────────────────────────────────────────────────
# PODCAST HOST
# Only one needed — whichever the show uses
# ────────────────────────────────────────────────────────────
PODCAST_HOST=transistor
# Transistor (https://transistor.fm)
TRANSISTOR_API_KEY=your-transistor-api-key
# Buzzsprout (https://buzzsprout.com)
BUZZSPROUT_API_KEY=your-buzzsprout-api-key
BUZZSPROUT_PODCAST_ID=your-podcast-id
# Captivate (https://captivate.fm)
CAPTIVATE_USER_ID=your-captivate-user-id
CAPTIVATE_API_KEY=your-captivate-api-key

# ────────────────────────────────────────────────────────────
# AI - LOCAL (Ollama — your RTX 2050)
# ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Which model to use for text tasks (caption gen, repurposing)
# Good options for RTX 2050 (4GB VRAM):
#   llama3.2  -> fastest local chat model in the default Ollama library
#   phi3:mini    → good quality/speed balance
#   mistral:7b   → best quality but may need quantization
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ────────────────────────────────────────────────────────────
# AI - CLOUD FALLBACK (optional, free tiers available)
# ────────────────────────────────────────────────────────────
# Gemini (free tier: 15 RPM, 1M tokens/day)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (free models available: DeepSeek V3, Llama 4 Scout)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Which AI provider to use: ollama | gemini | openrouter
AI_PROVIDER=ollama

# ────────────────────────────────────────────────────────────
# TRANSCRIPTION (for podcast clip suggestions)
# Deepgram free tier: 45hrs/lifetime
# ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ────────────────────────────────────────────────────────────
# WEB ANALYTICS (UTM tracking)
# ────────────────────────────────────────────────────────────
# GA4 Measurement Protocol
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your-ga4-api-secret

# ────────────────────────────────────────────────────────────
# EMAIL (for alerts + scheduled reports)
# Resend free tier: 3000 emails/month
# ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourshow.com

# ────────────────────────────────────────────────────────────
# MONITORING
# ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=feedforge-api
# Sentry (optional, free tier available)
SENTRY_DSN=

# ────────────────────────────────────────────────────────────
# RATE LIMITING & WORKER CONFIG
# ────────────────────────────────────────────────────────────
# How often to pull metrics per platform (in minutes)
METRICS_PULL_INTERVAL_YOUTUBE=60
METRICS_PULL_INTERVAL_INSTAGRAM=120
METRICS_PULL_INTERVAL_X=180
METRICS_PULL_INTERVAL_TIKTOK=120
METRICS_PULL_INTERVAL_LINKEDIN=240
METRICS_PULL_INTERVAL_PODCAST=360

# Worker concurrency
PUBLISH_WORKER_CONCURRENCY=5
METRICS_WORKER_CONCURRENCY=3

# ────────────────────────────────────────────────────────────
# SECURITY
# ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
